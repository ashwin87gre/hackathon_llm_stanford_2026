# Python API (FastAPI etc.) once exposed
VITE_API_BASE_URL=http://127.0.0.1:8000

# Supabase: Project Settings → API Keys → Project URL + Publishable key
# (Or Legacy tab: anon public JWT — both work with @supabase/supabase-js; use either in this var.)
# Copy this file to `.env` and fill in real values. Do not commit `.env`.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
